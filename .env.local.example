# ══════════════════════════════════════════════════════════════════════════════
# AFFILIATE PRODUCT PREVIEW LINKS
# ══════════════════════════════════════════════════════════════════════════════
#
# These are the Systeme.io PRODUCT PREVIEW pages your affiliates share.
# When someone clicks an affiliate's link, they land on this Systeme.io page,
# then click through to the actual checkout here.
#
# Each page shows the affiliate sidebar for OTHER products, not its own.
# Example: The Fundamentals checkout shows SUNYL, Encounter, etc. in the sidebar.
# ══════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_AFFILIATE_LINK_FUNDAMENTALS=https://jhericojohnbalasa.systeme.io/fundementals-truth
NEXT_PUBLIC_AFFILIATE_LINK_PRE_ENCOUNTER=https://jhericojohnbalasa.systeme.io/pre-encounter-truth
NEXT_PUBLIC_AFFILIATE_LINK_SUNYL=https://jhericojohnbalasa.systeme.io/sunyl-truth
NEXT_PUBLIC_AFFILIATE_LINK_ENCOUNTER=https://jhericojohnbalasa.systeme.io/encounter-truth
NEXT_PUBLIC_AFFILIATE_LINK_POST_ENCOUNTER=https://jhericojohnbalasa.systeme.io/post-encounter-truth
NEXT_PUBLIC_AFFILIATE_LINK_LIFEGROUP=https://jhericojohnbalasa.systeme.io/lifegroup-truth
# Add future products: NEXT_PUBLIC_AFFILIATE_LINK_MYPRODUCT=https://...


# ══════════════════════════════════════════════════════════════════════════════
# SECURITY — generate both secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Run it TWICE to get two different values. Never reuse between dev and prod.
# ══════════════════════════════════════════════════════════════════════════════

DOWNLOAD_TOKEN_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX_STRING
ADMIN_SESSION_SECRET=REPLACE_WITH_ANOTHER_DIFFERENT_32_BYTE_HEX


