# ============================================================
# MINISTRY CHECKOUT v3 — GCash Receipt Verification System
# ============================================================
# Copy to .env.local for local dev. NEVER commit real values.

# ─── GCash Merchant Info (shown on checkout page) ────────────
# Your GCash number customers will send money to
NEXT_PUBLIC_GCASH_NUMBER=09XX XXX XXXX
# Account name displayed (partial, as GCash shows it)
NEXT_PUBLIC_GCASH_NAME=J. Balasa

# ─── Product Pricing ─────────────────────────────────────────
NEXT_PUBLIC_PRODUCT_NAME=The Fundamentals
NEXT_PUBLIC_PRODUCT_PRICE=497
NEXT_PUBLIC_CURRENCY=PHP
# Price tolerance in pesos (allows ±tolerance for rounding)
PRICE_TOLERANCE=5

# ─── TEST MODE ───────────────────────────────────────────────
# When TEST_MODE=true, receipt verification is lenient:
# - Accepts any amount (ignores price check)
# - Accepts receipts from any date (ignores date check)
# - Still requires a valid GCash receipt QR structure
TEST_MODE=true

# ─── Download & Redirect ─────────────────────────────────────
# Systeme.io download/thank-you page URL
NEXT_PUBLIC_DOWNLOAD_PAGE_URL=https://jhericojohnbalasa.systeme.io/fundementals-truth
# URL to your actual digital file (hosted on Google Drive, S3, etc.)
# Make it a direct download link
PRODUCT_FILE_URL=https://drive.google.com/uc?export=download&id=YOUR_FILE_ID

# ─── Security ────────────────────────────────────────────────
# Secret to sign download tokens (generate: openssl rand -hex 32)
DOWNLOAD_TOKEN_SECRET=replace_with_32_byte_random_hex
# Token expiry in seconds (default 10 minutes)
DOWNLOAD_TOKEN_EXPIRY_SEC=600

# ─── Anti-Replay: Used Reference Numbers ─────────────────────
# In production, store used ref numbers in a DB (Redis, Supabase, etc.)
# For dev, we use an in-memory set (resets on server restart)
# Set to 'memory' for dev, 'redis' or 'supabase' for prod
RECEIPT_STORE=memory

# ─── Support Email ───────────────────────────────────────────
NEXT_PUBLIC_SUPPORT_EMAIL=jhericojohnbalasa@gmail.com

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
